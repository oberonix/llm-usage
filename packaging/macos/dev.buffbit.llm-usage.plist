<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>dev.buffbit.llm-usage</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Applications/llm-usage.app/Contents/MacOS/llm-usage</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/llm-usage.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/llm-usage.err.log</string>
</dict>
</plist>
